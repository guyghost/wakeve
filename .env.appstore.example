# Wakeve App Store submission environment.
# Copy values into your release shell or CI secret store. Do not commit real secrets.

# Apple values below are placeholders intentionally rejected by final gates.
# Replace them with real release secrets before submission.

# Apple account used by Fastlane/App Store Connect.
APPLE_ID=release@example.com

# Numeric App Store Connect team ID.
ITC_TEAM_ID=123456789

# Apple Developer Team ID used by Xcode signing.
TEAM_ID=ABCDE12345

# Apple Developer Team ID used by the deployed AASA endpoint.
# Must match TEAM_ID for this release so Universal Links match the signed app.
APPLE_TEAM_ID=ABCDE12345

# App Review contact phone. This placeholder is intentionally rejected by the
# final audit; use a real reachable secret/env value before submission.
# Prefer a secret/env value for this PII instead of committing
# composeApp/metadata/ios/review_information/phone_number.txt.
APP_REVIEW_PHONE_NUMBER=+15551234567

# Manual release signoffs required by scripts/app-store-submission-audit.sh.
# Set each to true only after completing the matching document/checklist.
# Final App Store upload also requires docs/APP_STORE_FINAL_SIGNOFF.md
# to contain APP_STORE_FINAL_SIGNOFF_COMPLETE=true.
#
# Evidence markers stay in the repository evidence documents, not in this env
# file. Before changing a signoff below, complete the matching evidence:
# - APP_STORE_PRIVACY_SIGNOFF -> docs/APP_STORE_PRIVACY_EVIDENCE.md with APP_STORE_PRIVACY_EVIDENCE_COMPLETE=true
# - APP_STORE_ACCESSIBILITY_SIGNOFF -> docs/APP_STORE_ACCESSIBILITY_EVIDENCE.md with APP_STORE_ACCESSIBILITY_EVIDENCE_COMPLETE=true
# - APP_STORE_AVAILABILITY_CONFIRMED -> docs/APP_STORE_AVAILABILITY_EVIDENCE.md with APP_STORE_AVAILABILITY_EVIDENCE_COMPLETE=true
# - APP_STORE_DSA_TRADER_STATUS_CONFIRMED -> docs/APP_STORE_DSA_TRADER_STATUS.md with APP_STORE_DSA_TRADER_STATUS_EVIDENCE_COMPLETE=true
# - APP_STORE_PRICING_AVAILABILITY_CONFIRMED -> docs/APP_STORE_PRICING_AVAILABILITY_EVIDENCE.md with APP_STORE_PRICING_AVAILABILITY_EVIDENCE_COMPLETE=true
# - APP_STORE_SDK_PRIVACY_CONFIRMED -> docs/APP_STORE_SDK_PRIVACY_EVIDENCE.md with APP_STORE_SDK_PRIVACY_EVIDENCE_COMPLETE=true
# - APP_STORE_RELEASE_CONTROL_CONFIRMED -> docs/APP_STORE_RELEASE_CONTROL_EVIDENCE.md with APP_STORE_RELEASE_CONTROL_EVIDENCE_COMPLETE=true
# - APP_STORE_MEDIA_LOCALIZATION_CONFIRMED -> docs/APP_STORE_MEDIA_LOCALIZATION_EVIDENCE.md with APP_STORE_MEDIA_LOCALIZATION_EVIDENCE_COMPLETE=true
# - APP_STORE_LICENSE_NOTICES_CONFIRMED -> docs/APP_STORE_LICENSE_NOTICES_EVIDENCE.md with APP_STORE_LICENSE_NOTICES_EVIDENCE_COMPLETE=true
# - APP_STORE_EULA_CONFIRMED -> docs/APP_STORE_EULA_EVIDENCE.md with APP_STORE_EULA_EVIDENCE_COMPLETE=true
# - APP_STORE_ACCOUNT_DELETION_CONFIRMED -> openspec/changes/add-in-app-account-deletion/ implemented and tested,
#   plus docs/APP_STORE_ACCOUNT_DELETION_EVIDENCE.md with APP_STORE_ACCOUNT_DELETION_EVIDENCE_COMPLETE=true
# - APP_STORE_UGC_MODERATION_CONFIRMED -> openspec/changes/add-ugc-moderation-controls/ implemented and tested,
#   plus docs/APP_STORE_UGC_MODERATION_EVIDENCE.md with APP_STORE_UGC_MODERATION_EVIDENCE_COMPLETE=true
# - APP_STORE_PAYMENT_COMPLIANCE_CONFIRMED -> docs/APP_STORE_PAYMENT_EVIDENCE.md with APP_STORE_PAYMENT_EVIDENCE_COMPLETE=true
# - TESTFLIGHT_SMOKE_PASSED -> docs/APP_STORE_TESTFLIGHT_EVIDENCE.md with TESTFLIGHT_SMOKE_EVIDENCE_COMPLETE=true
#   and docs/APP_STORE_OBSERVABILITY_EVIDENCE.md with APP_STORE_OBSERVABILITY_EVIDENCE_COMPLETE=true
# - APP_STORE_CAPABILITIES_CONFIRMED -> docs/APP_STORE_CAPABILITIES_EVIDENCE.md with APP_STORE_CAPABILITIES_EVIDENCE_COMPLETE=true
# Final signoff additionally requires docs/APP_STORE_REVIEW_ACCESS_EVIDENCE.md
# with APP_STORE_REVIEW_ACCESS_EVIDENCE_COMPLETE=true,
# docs/APP_STORE_ACCOUNT_ACCESS_EVIDENCE.md with
# APP_STORE_ACCOUNT_ACCESS_EVIDENCE_COMPLETE=true, and
# docs/APP_STORE_EXPORT_COMPLIANCE_EVIDENCE.md with
# APP_STORE_EXPORT_COMPLIANCE_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_APP_INFORMATION_EVIDENCE.md with
# APP_STORE_APP_INFORMATION_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_VERSIONING_EVIDENCE.md with
# APP_STORE_VERSIONING_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_RELEASE_ARTIFACT_EVIDENCE.md with
# APP_STORE_RELEASE_ARTIFACT_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_CONTENT_RIGHTS_EVIDENCE.md with
# APP_STORE_CONTENT_RIGHTS_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_LICENSE_NOTICES_EVIDENCE.md with
# APP_STORE_LICENSE_NOTICES_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_EULA_EVIDENCE.md with
# APP_STORE_EULA_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_ACCOUNT_DELETION_EVIDENCE.md with
# APP_STORE_ACCOUNT_DELETION_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_UGC_MODERATION_EVIDENCE.md with
# APP_STORE_UGC_MODERATION_EVIDENCE_COMPLETE=true, plus
# docs/APP_STORE_LIVE_URL_AASA_EVIDENCE.md with APP_STORE_LIVE_URL_AASA_EVIDENCE_COMPLETE=true.
APP_STORE_PRIVACY_SIGNOFF=false
APP_STORE_ACCESSIBILITY_SIGNOFF=false
APP_STORE_AVAILABILITY_CONFIRMED=false
APP_STORE_DSA_TRADER_STATUS_CONFIRMED=false
APP_STORE_PRICING_AVAILABILITY_CONFIRMED=false
APP_STORE_SDK_PRIVACY_CONFIRMED=false
APP_STORE_RELEASE_CONTROL_CONFIRMED=false
APP_STORE_MEDIA_LOCALIZATION_CONFIRMED=false
APP_STORE_LICENSE_NOTICES_CONFIRMED=false
APP_STORE_EULA_CONFIRMED=false
APP_STORE_ACCOUNT_DELETION_CONFIRMED=false
APP_STORE_UGC_MODERATION_CONFIRMED=false
APP_STORE_PAYMENT_COMPLIANCE_CONFIRMED=false
TESTFLIGHT_SMOKE_PASSED=false
APP_STORE_CAPABILITIES_CONFIRMED=false
